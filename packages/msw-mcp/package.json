{
  "name": "msw-mcp",
  "version": "1.3.3",
  "description": "MCP server for Mock Service Worker AI interaction",
  "type": "module",
  "bin": {
    "msw-mcp": "./build/index.js"
  },
  "main": "build/index.js",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "pnpm run build && node build/index.js",
    "start": "node build/index.js",
    "prepublishOnly": "pnpm run build",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.22.0",
    "@msw-mcp/core": "workspace:*",
    "@msw-mcp/client": "workspace:*",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "msw": "^2.11.0"
  },
  "peerDependenciesMeta": {
    "msw": {
      "optional": true
    }
  },
  "keywords": [
    "mcp",
    "mock-service-worker",
    "msw",
    "ai",
    "testing"
  ],
  "author": "",
  "license": "MIT"
}
